{
    "name": "vscode-bongo",
    "displayName": "Bongo",
    "description": "Language support for .bongo build files",
    "version": "0.0.1",
    "publisher": "bongoci",
    "engines": {
        "vscode": "^1.82.0"
    },
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "bongo",
                "extensions": [
                    ".bongo"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "bongo",
                "scopeName": "source.bongo",
                "path": "./syntaxes/bongo.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "bongo",
                "path": "./snippets/bongo.json"
            }
        ],
        "configuration": {
            "title": "Bongo",
            "properties": {
                "bongo.serverPath": {
                    "type": "string",
                    "default": "",
                    "description": "Path to the bongo-ls binary. Leave empty to use PATH."
                }
            }
        }
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/node": "^20.19.41",
        "@types/vscode": "^1.82.0",
        "typescript": "^5.3.0"
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    }
}
