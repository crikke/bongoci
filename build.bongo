# this is a comment
BONGOVER = 1
MODULE:
    NAME = "ci"
    BASE_IMAGE = "golang:1.25"
    EXPORT:
        INPUT BUILD_BONGOCI BUILD
        INPUT TEST RESULT

BUILD_BONGOCI:
    OUTPUT "BUILD" "./bongoci"
    CMD "go build -o ./bongoci ./cmd/bongoci"

TEST:
    OUTPUT "RESULT" "./coverage.out"
    CMD "go test -coverprofile=coverage.out pkg/..."